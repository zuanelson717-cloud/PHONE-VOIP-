rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.sender is string && data.sender.size() > 0 && data.sender.size() <= 128 &&
             data.createdAt is number;
    }

    match /chatMessages/{messageId} {
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(messageId) && isValidChatMessage(request.resource.data);
    }

    match /fcmTokens/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
